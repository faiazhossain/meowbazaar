# ============================================
# PetBazaar Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Never commit .env file to version control

# ============================================
# App Configuration
# ============================================
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=PetBazaar
NEXT_PUBLIC_DEFAULT_LOCALE=bn

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/petbazaar

# ============================================
# Authentication Configuration
# ============================================
# Secret key for NextAuth.js session encryption
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-key-min-32-characters

# NextAuth.js secret (if different from AUTH_SECRET)
NEXTAUTH_SECRET=your-nextauth-secret-key-min-32-characters

# ============================================
# Email Configuration
# ============================================
# Resend API key for sending emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Sender email address
# Note: With Resend free tier, you can only send to your Resend account email
# To send to any email, verify your domain at https://resend.com/domains
EMAIL_FROM=noreply@petbazaar.com

# Email reply-to address (optional)
EMAIL_REPLY_TO=support@petbazaar.com

# ============================================
# SMS Configuration (Bangladesh)
# ============================================
# SMS Provider: bdfree, sslcommerz, teletalk
SMS_PROVIDER=bdfree
SMS_API_KEY=your-sms-api-key

# SMS Sender ID (if supported by provider)
SMS_SENDER=PetBazar

# ============================================
# Payment Gateway Configuration
# ============================================

# SSLCommerz (Card Payments)
# Get credentials from: https://sandbox.sslcommerz.com/
SSLCOMMERZ_STORE_ID=your-store-id
SSLCOMMERZ_STORE_PASSWORD=your-store-password
SSLCOMMERZ_SANDBOX=true

# bKash (Mobile Payment)
# Get credentials from: https://developer.bka.sh/
BKASH_MERCHANT_ID=your-merchant-id
BKASH_USERNAME=your-username
BKASH_PASSWORD=your-password
BKASH_APP_SECRET=your-app-secret

# Nagad (Mobile Payment)
# Get credentials from: https://developer.nagad.com/
NAGAD_MERCHANT_ID=your-merchant-id

# ============================================
# Pusher Real-time Configuration
# ============================================
# Get credentials from: https://dashboard.pusher.com/
NEXT_PUBLIC_PUSHER_KEY=your-pusher-key
NEXT_PUBLIC_PUSHER_CLUSTER=your-pusher-cluster
PUSHER_APP_ID=your-pusher-app-id
PUSHER_SECRET=your-pusher-secret

# ============================================
# Cloudinary Image Upload Configuration
# ============================================
# Get credentials from: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=petbazaar-products
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ============================================
# ImageBB Image Upload Configuration (Foster Home Images)
# ============================================
# Get free API key from: https://imgbb.com/settings/api
IMAGE_BB_API_KEY=your-imagebb-api-key

# ============================================
# Social Providers (Optional)
# ============================================
# Google OAuth (if enabling Google login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth (if enabling Facebook login)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ============================================
# Analytics & Monitoring
# ============================================
# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry Error Tracking (optional)
# Get from: https://sentry.io/
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ============================================
# Node Environment
# ============================================
NODE_ENV=development

# Set to 'production' when deploying to production
